# Container sets MCP_HOST/MCP_PORT/MCP_TRANSPORT, DATA_ROOT (/app/state/data),
# LEAN_DATA_ROOT (/lean-data), and OPENBB_AUTO_BUILD; this file is secrets + posture only.

# --- MCP-native OAuth (public serving to Claude via the tunnel overlay) ---
# Off (0) = loopback / no-auth mode. On (1) = require Google OAuth (the server then
# emits the OAuth discovery metadata claude.ai web/mobile connectors need).
MCP_AUTH_ENABLED=1
# Public HTTPS base URL Claude connects to (no trailing slash, no /mcp). Under compose
# the tunnel overlay stamps this from the root .env's MCP_DOMAIN; set it here only when
# running outside compose.
#MCP_PUBLIC_URL=https://data.example.com
# Google OAuth client (Web application). Authorized redirect URI must be exactly
# <MCP_PUBLIC_URL>/auth/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated Google emails allowed to use this server. REQUIRED when
# MCP_AUTH_ENABLED=1 (empty = server refuses to start, fail closed).
MCP_ALLOWED_GOOGLE_EMAILS=

# --- OpenBB provider credentials ---
# REQUIRED: Tiingo is the fixed provider for crypto ingest, so without this key the
# ingest tool fails. OpenBB does NOT read this env var itself — feeds.py injects it
# onto obb.user.credentials. Get a key at https://tiingo.com. Egress allowlist:
# api.tiingo.com.
TIINGO_API_KEY=
