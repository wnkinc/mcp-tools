# MCP server settings.
# NOTE: MCP_PORT is read by main() and is also set in the systemd unit's
# Environment= (8062) for the public instance; keep them in sync.
MCP_HOST=127.0.0.1
MCP_PORT=8062

# --- MCP-native OAuth (public serving to Claude via Cloudflare; mcp-tools) ---
# Off (0) = loopback / no-auth mode. On (1) = require Google OAuth (the server then
# emits the OAuth discovery metadata claude.ai web/mobile connectors need).
MCP_AUTH_ENABLED=0
# Public HTTPS base URL Claude connects to (no trailing slash, no /mcp).
MCP_PUBLIC_URL=https://data.secure-agentic-engineering.com
# Google OAuth client (Web application). Authorized redirect URI must be exactly
# <MCP_PUBLIC_URL>/auth/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated Google emails allowed to use this server. REQUIRED when
# MCP_AUTH_ENABLED=1 (empty = server refuses to start, fail closed).
MCP_ALLOWED_GOOGLE_EMAILS=

# --- OpenBB (the data engine) ---
# OpenBB code-generates its `obb` accessor into the venv at install time. Freeze it and
# disable the import-time auto-rebuild so NOTHING writes into the (read-only) venv on the
# hardened unit. Build once at setup: `.venv/bin/python -c "import openbb"`. Re-enable
# (or just rerun that build) only after adding/removing an OpenBB extension.
OPENBB_AUTO_BUILD=false
# OpenBB also writes settings to $HOME/.openbb_platform. Under the systemd unit HOME is
# pointed at the writable StateDirectory (see systemd/mcp-data.service), so there is
# nothing to set here; for LOCAL dev it falls back to your real home.

# --- Data lake / ingest knobs ---
# Where the canonical parquet lake lives. Empty default = <tool dir>/var/data, which
# is fine for LOCAL dev. Under the hardened systemd unit (ProtectHome=read-only) the
# home dir is NOT writable, so you MUST point this at the unit's StateDirectory:
#     DATA_ROOT=/var/lib/mcp-data/data
# (Any tool that writes files hits this; the StateDirectory is the writable path.)
DATA_ROOT=
# Ingest thread-pool size (ingest is I/O-bound; a small pool is plenty).
DATA_MAX_WORKERS=4
# Seconds data-ingest blocks for a fast run before returning a PENDING run_id.
DATA_INLINE_BUDGET_S=20
