# Container sets MCP_HOST/MCP_PORT/MCP_TRANSPORT; this file is secrets + posture only.

# --- Workspace auth (the ENGINE's Google OAuth: acting on YOUR Google account) ---
# Reuses the stack's shared Google OAuth client (Google Cloud Console -> Credentials).
# Two one-time console steps for this tool:
#   1. Add https://workspace.<your-domain>/oauth2callback to the client's
#      Authorized redirect URIs (alongside each tool's /auth/callback).
#   2. Enable the Workspace APIs you'll use (Gmail, Drive, Calendar, Docs, Sheets,
#      Slides, Chat, Forms, Tasks, People, Apps Script, Custom Search) and add
#      their scopes to the consent screen (test mode with yourself as user works).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Your Google account -- single-user mode authenticates this one user.
USER_GOOGLE_EMAIL=

# --- Engine settings (defaults set by server.py; override here if needed) ---
# All services, all tools by default. Narrow with the engine's own knobs:
#WORKSPACE_MCP_TOOL_TIER=core          # core | extended | complete; empty = all
#WORKSPACE_MCP_TOOLS=gmail,drive       # service subset; empty = all
# The public overlay stamps WORKSPACE_EXTERNAL_URL + GOOGLE_OAUTH_REDIRECT_URI from
# MCP_DOMAIN; set them here only when running outside compose.
#WORKSPACE_EXTERNAL_URL=https://workspace.example.com
#GOOGLE_OAUTH_REDIRECT_URI=https://workspace.example.com/oauth2callback

# --- MCP-native OAuth (OURS: who may connect Claude; see security/auth.py) ---
MCP_AUTH_ENABLED=1
#MCP_PUBLIC_URL=https://workspace.example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MCP_ALLOWED_GOOGLE_EMAILS=
