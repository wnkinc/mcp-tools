# Container sets MCP_HOST/MCP_PORT/MCP_TRANSPORT; this file is secrets + posture only.
MCP_AUTH_ENABLED=1
# MCP_PUBLIC_URL is stamped by the tunnel overlay from the root .env's MCP_DOMAIN;
# set it here only when running outside compose.
#MCP_PUBLIC_URL=https://browser.example.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MCP_ALLOWED_GOOGLE_EMAILS=

# Gates the noVNC live-view page (any passphrase). UNSET = no live view: the
# entrypoint then never starts x11vnc/websockify (fail closed), and
# browser_live_view reports the view as unavailable.
BROWSER_VIEW_PASSWORD=

# Optional knobs (defaults shown). BROWSER_HEADLESS=1 skips the X/VNC stack and
# runs Chromium headless -- no live view. BROWSER_CAPS trims the engine's opt-in
# tool groups if the full surface is ever too much.
#BROWSER_WIDTH=1280
#BROWSER_HEIGHT=800
#BROWSER_HEADLESS=0
#BROWSER_CAPS=config,devtools,network,pdf,storage,testing,vision

# ------------------------------------------------------------------------------
# browser-sync (the artifacts->Drive sidecar in docker-compose.yml) needs a
# one-time token mint on a machine with a browser -- nothing in this file. Run:
#
#   docker run --rm -it --network host \
#     -v mcp-tools_browser-sync-state:/config/rclone \
#     rclone/rclone:1.72.0 config
#
# rclone's config wizard has a lot of prompts; here is every answer in order:
#
#   n/s/q>              n        (new remote)
#   name>               gdrive   (exactly this -- the sync loop uses gdrive:)
#   Storage>            22       (Google Drive; the number may shift between
#                                 rclone versions -- pick the "drive" entry)
#   client_id>          <Enter>  (blank = rclone's built-in app)
#   client_secret>      <Enter>
#   scope>              3        (drive.file: only files this remote creates)
#   service_account_file> <Enter>
#   Edit advanced config?                       n
#   Use web browser to automatically authenticate?  y
#     -> a browser tab opens: pick your Google account, click Allow
#   Configure this as a Shared Drive (Team Drive)?  n
#   Keep this "gdrive" remote?                  y
#   n/s/q>              q        (done)
#
# The token lands in the browser-sync-state volume; the sidecar picks it up on
# its next 30s pass. Files appear in a Drive folder named "browser-artifacts".
# ------------------------------------------------------------------------------
