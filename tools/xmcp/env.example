# Required auth: read-only app-only Bearer token (from the X developer portal).
X_BEARER_TOKEN=

# X API settings
X_API_BASE_URL=https://api.x.com
X_API_TIMEOUT=30
X_API_DEBUG=1

# MCP server settings
# NOTE: MCP_PORT is read by main() BEFORE .env loads, so for the systemd-run
# public instance it is set in the unit's Environment= (8061), not here.
MCP_HOST=127.0.0.1
MCP_PORT=8061

# --- MCP-native OAuth (public serving to Claude via Cloudflare; mcp-tools) ---
# Off (0) = loopback / no-auth mode (e.g. a local agent on 127.0.0.1).
# On  (1) = require Google OAuth; the server then emits OAuth discovery metadata
#           + the WWW-Authenticate header that claude.ai web/mobile connectors need.
MCP_AUTH_ENABLED=0
# Public HTTPS base URL Claude connects to (no trailing slash, no /mcp). Under compose
# the tunnel overlay stamps this from the root .env's MCP_DOMAIN; set it here only when
# running outside compose.
#MCP_PUBLIC_URL=https://xmcp.example.com
# Google OAuth client creds: Google Cloud Console -> APIs & Services -> Credentials
# -> OAuth client ID (Web application). The "Authorized redirect URI" must be
# exactly <MCP_PUBLIC_URL>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated Google account emails allowed to use this server.
# REQUIRED when MCP_AUTH_ENABLED=1 (empty = server refuses to start, fail closed).
# (While the consent screen is in "Testing", also add these as test users.)
MCP_ALLOWED_GOOGLE_EMAILS=

# --- Slack out-of-band approvals (optional) ---
# Approval Slack delivery moved to the approval sidecar -- configure it ONCE in
# security/approval/service/env.example (tools no longer hold Slack secrets).

# Every tool is gated behind human approval by default. Comma-separated tool names
# here are EXEMPT (run without approval) -- e.g. cheap read-only lookups.
MCP_APPROVAL_EXEMPT=

# --- Layer-4 guardrail (untrusted-content screening) ---
# Every X result is screened for prompt-injection by the guardrail service before it
# reaches the model. FAILS CLOSED: if the service is down, results are withheld.
# Run the service from security/guardrail/service (loopback :8071).
GUARDRAIL_ENABLED=1
GUARDRAIL_URL=http://127.0.0.1:8071

# Tool filtering (optional, comma-separated)
# DEFAULT-DENY: blank here does NOT mean "expose everything" -- the server falls
# back to a code-enforced read-only default (DEFAULT_READ_ALLOWLIST in server.py:
# 8 read ops). Set this only to NARROW or customize that grant.
X_API_TOOL_ALLOWLIST=

# Write-guard (THREAT-MODEL L1): non-GET (mutate) X operations -- post, delete, DM,
# follow, block, etc. -- are NEVER exposed as tools unless this is explicitly truthy,
# regardless of what X_API_TOOL_ALLOWLIST contains. Leave 0 for a read-only server.
X_API_ALLOW_WRITES=0

# Grok x_search tool (xAI). XAI_API_KEY enables the grok_x_search tool; XAI_MODEL
# is the model lever (default grok-4-1-fast; use a *-reasoning model for depth).
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast
