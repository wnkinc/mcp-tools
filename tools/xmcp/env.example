# Container sets MCP_HOST/MCP_PORT/MCP_TRANSPORT; this file is secrets + posture only.

# --- X auth (developer portal -> your app -> "Keys and tokens") ---
# Preferred: OAuth1 user-context -- ALL requests are signed and act as YOUR account
# (required for writes; upstream xdevplatform/xmcp's auth path). All four values or
# the OAuth1 path is off. Consumer key/secret = the app's "API Key and Secret";
# access token/secret = the "Access Token and Secret" card, generated AFTER the
# app's user-authentication permission is set to read+write (regenerate if it
# predates that -- the card labels which permission it was created with). Tokens
# don't expire. NOTE: the wizard also hands out an OAuth2 Client ID/Secret; those
# are a different auth system and unused here.
X_OAUTH_CONSUMER_KEY=
X_OAUTH_CONSUMER_SECRET=
X_OAUTH_ACCESS_TOKEN=
X_OAUTH_ACCESS_TOKEN_SECRET=

# Fallback: read-only app-only Bearer token (writes fail at X with this alone).
X_BEARER_TOKEN=

# X API settings
X_API_BASE_URL=https://api.x.com
X_API_TIMEOUT=30
X_API_DEBUG=1

# --- MCP-native OAuth (public serving to Claude via Cloudflare; mcp-tools) ---
# Off (0) = loopback / no-auth mode (e.g. a local agent on 127.0.0.1).
# On  (1) = require Google OAuth; the server then emits OAuth discovery metadata
#           + the WWW-Authenticate header that claude.ai web/mobile connectors need.
MCP_AUTH_ENABLED=1
# Public HTTPS base URL Claude connects to (no trailing slash, no /mcp). Under compose
# the tunnel overlay stamps this from the root .env's MCP_DOMAIN; set it here only when
# running outside compose.
#MCP_PUBLIC_URL=https://xmcp.example.com
# Google OAuth client creds: Google Cloud Console -> APIs & Services -> Credentials
# -> OAuth client ID (Web application). The "Authorized redirect URI" must be
# exactly <MCP_PUBLIC_URL>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated Google account emails allowed to use this server.
# REQUIRED when MCP_AUTH_ENABLED=1 (empty = server refuses to start, fail closed).
# (While the consent screen is in "Testing", also add these as test users.)
MCP_ALLOWED_GOOGLE_EMAILS=

# --- Out-of-band approvals (optional) ---
# Approval delivery is configured ONCE in the approval sidecar
# (security/approval/service/env.example -- tools no longer hold channel secrets).
# WHICH tools need approval is the sidecar's stored modes, curated at runtime via
# the gatekeeper tool: every tool defaults to always_allow until changed there.

# --- Layer-4 guardrail (untrusted-content screening) ---
# Every X result is screened for prompt-injection by the guardrail service before it
# reaches the model. FAILS CLOSED: if the service is down, results are withheld.
# Run the service from security/guardrail/service (loopback :8071).
GUARDRAIL_ENABLED=1
GUARDRAIL_URL=http://127.0.0.1:8071

# Tool filtering (optional, comma-separated)
# DEFAULT-DENY: blank here does NOT mean "expose everything" -- the server falls
# back to a code-enforced read-only default (DEFAULT_READ_ALLOWLIST in server.py:
# 8 read ops). Set a comma-separated list to NARROW or customize that grant, or
# the single sentinel `all` to expose the full spec surface (still write-guarded
# and stream/webhook-excluded).
X_API_TOOL_ALLOWLIST=

# Write-guard (THREAT-MODEL L1): non-GET (mutate) X operations -- post, delete, DM,
# follow, block, etc. -- are NEVER exposed as tools unless this is explicitly truthy,
# regardless of what X_API_TOOL_ALLOWLIST contains. Leave 0 for a read-only server.
# NOTE: exposed writes surface in Claude's UI (write/delete permission category) and
# start always_allow like every tool -- gate or block individual ones at runtime via
# the gatekeeper (docs/GATEKEEPER.md). Without user-context OAuth the CALLS fail at X
# anyway -- X_BEARER_TOKEN is an app-only credential and cannot act as an account.
X_API_ALLOW_WRITES=0
