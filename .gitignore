.DS_Store
__pycache__/
*.py[cod]
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/

# Secrets: never commit. Each tool keeps its own .env (see <tool>/env.example).
.env
.env.*
!env.example
!*/env.example

# Cloudflare tunnel credentials (the ingress secret). Routing config is committed;
# the creds JSON is injected per-host and must never land in git.
security/ingress/secrets/

vendor/

# Claude Code local (per-machine) settings; the deploy skill in .claude/skills IS committed.
.claude/settings.local.json
