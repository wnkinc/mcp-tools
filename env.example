# Deployment identity -- the one file you edit to make this stack yours.
#
#   cp env.example .env      # .env is gitignored
#
# Docker Compose interpolates these variables into the compose files at `up` time.
# The base (local, auth-off) stack needs only COMPOSE_PROFILES -- the rest matter
# solely to the public docker-compose.tunnel.yml overlay. Per-tool secrets (API keys,
# Google OAuth client, email allowlist) stay in each tool's own tools/<tool>/.env.

# Which TOOLS to run -- the only deploy-time choice. Every tool carries a compose
# profile named after itself, so only the tools listed here are built and started
# (their images aren't even pulled). Available: xmcp, data, lean, telegram, workspace.
#   - lean needs data (it backtests the data tool's exported lake) and its base
#     image is ~13GB -- add it only if you want backtesting.
# Everything else runs without being asked: the egress wall, the approval sidecar,
# the gatekeeper (attach its connector to use it), and the guardrail -- which starts
# automatically alongside any untrusted-output tool (xmcp, telegram) and stays out
# of a deployment that has neither.
COMPOSE_PROFILES=xmcp,data

# --- Guardrail (output screening) ------------------------------------------------
# The guardrail itself is automatic (see COMPOSE_PROFILES above); the ONE decision
# here is which screening engine runs behind it:
#   llamafirewall -- local model (default; the local-deploy choice). Set HF_TOKEN
#                    below so the first start can pull the gated PromptGuard model.
#   bedrock       -- Amazon Bedrock Guardrails API (the AWS-deploy choice). Set the
#                    BEDROCK_* values; deploy/aws provisions and fills them in.
GUARDRAIL_PROVIDER=llamafirewall
# Escape hatch, not a choice: 0 lets the untrusted tools (xmcp, telegram) return
# output UNSCREENED. Leave at 1 -- with it on and the screen broken they fail
# closed (results withheld, the message names the cause).
GUARDRAIL_ENABLED=1
# bedrock provider only: the Guardrail to call and its region (the guardrail's
# egress allowlist pins the matching bedrock-runtime endpoint).
#BEDROCK_GUARDRAIL_ID=
#BEDROCK_GUARDRAIL_VERSION=DRAFT
#AWS_REGION=us-east-1

# --- Approvals (human-in-the-loop for gated tool calls) --------------------------
# The server-side version of Claude's per-tool "always allow / needs approval /
# blocked" -- enforced HERE because the desktop toggle is sticky (approve once and
# it sticks across every chat) and doesn't reliably apply to custom connectors. Its
# purpose: keep dangerous tool calls behind a human tap. The gated tools (xmcp,
# telegram) default to NEEDS APPROVAL on the public overlay -- a gated write call
# posts an Approve/Deny card to your approval channel and reports a pending status
# in chat until you tap the card. The three postures:
#   - Needs approval (default): leave this unset. A channel MUST be configured in
#     security/approval/service/.env (APPROVAL_PROVIDER = slack, discord, or
#     telegram), or every gated call fails "approval undeliverable" -- no silent
#     fallback. Pick a channel the agent does NOT operate: if its own tools can
#     read the card and press the buttons, the gate approves itself.
#   - Always allow: MCP_REQUIRE_APPROVAL=0 -- gated write actions run ungated.
#   - Blocked: don't deploy that tool at all (drop it from the tools list).
#MCP_REQUIRE_APPROVAL=0

# Parent domain the tools are served under; each tool gets its own subdomain
# (xmcp.<MCP_DOMAIN>, data.<MCP_DOMAIN>, ...). The domain must be on Cloudflare.
MCP_DOMAIN=example.com

# Cloudflare tunnel UUID -- the deploy/cloudflare Pulumi stack's tunnelId output.
# Its credsJson output goes to security/ingress/secrets/creds.json (gitignored);
# see docs/deploy/local.md step 3.
TUNNEL_ID=

# uid:gid that owns the staged creds.json; the cloudflared container runs as this
# user so it can read the mounted secret. Defaults to 1000:1000.
#HOST_UID=1000
#HOST_GID=1000

# llamafirewall provider: Hugging Face token so the guardrail sidecar can pull its
# gated screening model on first start (request access to
# meta-llama/Llama-Prompt-Guard-2-86M on huggingface.co first). Until the model is
# cached the guardrail runs degraded (HiddenASCII-only; see its /healthz).
#HF_TOKEN=
